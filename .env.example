# ========================
# Graphiti Custom Local Config
# ========================

# OpenAI-compatible endpoints (OpenAI / Azure / Ollama / gateway proxy)
OPENAI_API_KEY=replace-with-your-key-or-ollama
OPENAI_API_URL=http://127.0.0.1:11434/v1
OPENAI_ORGANIZATION_ID=

# Ollama local recommendation
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Neo4j (optional)
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

# FalkorDB / RedisGraph (default)
FALKORDB_URI=redis://127.0.0.1:6379
FALKORDB_PORT=6379
FALKORDB_USER=
FALKORDB_PASSWORD=
FALKORDB_DATABASE=default_db

# Runtime and concurrency
USE_PARALLEL_RUNTIME=false
SEMAPHORE_LIMIT=10
MAX_REFLEXION_ITERATIONS=1
GRAPHITI_GROUP_ID=main
GRAPHITI_USER_ID=mcp_user

# Optional providers
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=
VOYAGE_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
